# Enable Rewrite Engine
RewriteEngine On
Options -MultiViews
RewriteBase /

# -----------------------------------
# STEP 1: Force HTTPS (fixes http:// errors)
# -----------------------------------
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

# -----------------------------------
# STEP 2: Force non-WWW (fixes www. errors)
# -----------------------------------
RewriteCond %{HTTP_HOST} ^www\.touranzza\.com [NC]
RewriteRule ^(.*)$ https://touranzza.com/$1 [R=301,L]

# -----------------------------------
# STEP 3: Fix .php URLs - 301 PERMANENT
# -----------------------------------
RewriteCond %{THE_REQUEST} \s.*/index\.php[\s?] [NC]
RewriteRule ^index\.php$ ./ [L,R=301]

RewriteCond %{THE_REQUEST} \s/([^.]+)\.php[\s?] [NC]
RewriteRule ^([^.]+)\.php$ $1 [L,R=301]

# -----------------------------------
# STEP 4: Internal rewrite to .php
# -----------------------------------
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.php -f
RewriteRule ^([^/]+)/?$ $1.php [L]

# -----------------------------------
# STEP 5: 4XX Broken URL Fixes - 301 PERMANENT
# -----------------------------------
Redirect 301 /same-day-agra-tour-by-train https://touranzza.com/same-day-agra-tour-by-gatimaan-express
Redirect 301 /golden-triangle-tour-india https://touranzza.com/golden-triangle-tours
Redirect 301 /taj-mahal-tour-packages https://touranzza.com/tour-packages
Redirect 301 /agra-tours https://touranzza.com/same-day-tours